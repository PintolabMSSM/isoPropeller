#!/usr/bin/env perl
=start
Author: ALin
Purpose: To split merged transcripts generated by isoPropeller_merge_x based on 5' and 3' ends distance.
Change log:
	v1.1	2023-09	It was modified from isoPropeller_merge v1.5
	v1.2	2023-12 Fixed a typo in creating temp_sub_transcript_ref. Fixed an issue of getting gtf attributes. Modified to handle monoexonic and multiexonic transcripts equally. Added the outputs for new TSS and TTS bed files.
=cut

use strict;
use Getopt::Long;
use List::Util qw(max min);
use threads;
use Benchmark qw(:hireswallclock);

my $total_start_time = Benchmark->new;

my $version = "v1.2";

my ($in, $out, $gtf, $id, $five_diff, $three_diff, $min_depth, $num_thread, $help) = ("", "", "", "", 1000, 300, 2, 1, 0);

my $usage = "Usage: perl isoPropeller_merge_split
	-i <String> Input list of _end_dist.txt file(s)
	-o <String> Output base
	-g <String> The merged gtf file generated by isoPropeller_merge_*
	-d <String> The _id.txt file generated by isoPropeller_merge_
	-a <Integer> Maximum 5' end difference (Default: $five_diff)
	-b <Integer> Maximum 3' end difference (Default: $three_diff)
	-m <Integer> Minimum transcript read depth (Default: $min_depth)
	-t <Integer> The number of threads to use (Default: $num_thread)
	-h <Boolean> Help
";

GetOptions(
	'i=s'	=>	\$in,
	'o=s'	=>	\$out,
	'g=s'	=>	\$gtf,
	'd=s'	=>	\$id,
	'a=i'	=>	\$five_diff,
	'b=i'	=>	\$three_diff,
	'm=i'	=>	\$min_depth,
	't=i'	=>	\$num_thread,
        'h!'    =>      \$help,
);

if($help){
        print "$usage";
        exit;
}

unless($in && $out && $gtf && $id){
	print "$usage";
	exit;
}

open(my $out_fh, "> ${out}.gtf") or die "<ERROR> Cannot create ${out}.gtf!\n";
my $date_format = "+%F-%T.%3N";
my $date = `date $date_format`;
chomp $date;
print "[$date]\tperl isoPropeller_merge_split -i $in -o $out -g $gtf -d $id -a $five_diff -b $three_diff -m $min_depth -t $num_thread\n";
print $out_fh "#perl isoPropeller_merge -i $in -o $out -g $gtf -d $id -a $five_diff -b $three_diff -m $min_depth -t $num_thread\n";
close $out_fh;

my $dir = "${out}__isoPropeller_merge_split_temp";
if(-d $dir){
	print STDERR "<WARNNING> Temporary directory $dir exists! Will overwrite it...\n";
	system("rm ${dir}/*");
}
else{
	system("mkdir $dir");
}

my $total_thread = `grep -c \"^processor\" /proc/cpuinfo`;
chomp $total_thread;
$date = `date $date_format`;
chomp $date;
print "[$date]\tA total of $total_thread threads detected\n";

if($num_thread > $total_thread){
	print "<WARNING> Exceeding the maximal total number of threads! Setting the number of thread to $total_thread...";
	$num_thread = $total_thread;
}

my $start_time = Benchmark->new;
$date = `date $date_format`;
chomp $date;
print "[$date]\tStarting preprocessing...\n";
my $chr_ref = get_chromosome($gtf);
my $finish_time = Benchmark->new;
my $time_spent = timediff($finish_time, $start_time);
$date = `date $date_format`;
chomp $date;
print "[$date]\tUsed ". timestr($time_spent) . " for preprocessing\n";

my $chr_pos = 0;
my @thread = ();
my @running = ();

while(@thread < @$chr_ref){
	@running = threads->list(threads::running);
	if(@running < $num_thread){
		my $thread = threads->create(\&worker, $chr_ref->[$chr_pos], $dir, $date_format, $in, $gtf, $id, $five_diff, $three_diff, $min_depth);
		push(@thread, $thread);
		$chr_pos++;
	}
}

foreach my $thread (@thread){
	my @result = $thread->join();
	$date = `date $date_format`;
	chomp $date;
	print "[$date]\tJoined for $result[0]!\n";
}

system("cat ${dir}/*.gtf | sort -k 1,1 -k 4,4n >> ${out}.gtf");
system("cat ${dir}/*_tss.bed | sort -k 1,1 -k 2,2n > ${out}_tss.bed");
system("cat ${dir}/*_tts.bed | sort -k 1,1 -k 2,2n > ${out}_tts.bed");
open(my $in_fh, $in) or die "<ERROR> Cannot open $in!\n";
open(my $exp_fh, "> ${out}_exp.txt") or die "<ERROR> Cannot create ${out}_exp.txt!\n";
print $exp_fh "transcript_id";
while(<$in_fh>){
	chomp;
	my $file = $_;
	$file =~ s/\r//;
	print $exp_fh "\t$file";
}
print $exp_fh "\n";
close $in_fh;
close $exp_fh;
system("cat ${dir}/*_exp.txt | sort -k 1 >> ${out}_exp.txt");
$date = `date $date_format`;
chomp $date;
print "[$date]\tGenerated output files!\n";
system("rm -r ${dir}");
$date = `date $date_format`;
chomp $date;
print "[$date]\tCleaned temporary files!\n";

my $total_finish_time = Benchmark->new;
my $total_time_spent = timediff($total_finish_time, $total_start_time);
$date = `date $date_format`;
chomp $date;
print "[$date]\tTotal time used: ". timestr($total_time_spent) . "\n";

sub worker{
	my ($temp_chr, $temp_dir, $temp_date_format, $temp_in, $temp_gtf, $temp_id, $temp_five_diff, $temp_three_diff, $temp_min_depth) = @_;
	my $temp_date = `date $temp_date_format`;
	chomp $temp_date;
	print "[$temp_date]\tStarting to process $temp_chr...\n";
	my $temp_start_time = Benchmark->new;
	my ($temp_gene_ref, $temp_transcript_ref) = read_gtf($temp_chr, $temp_gtf);
	my ($temp_id_ref) = read_id($temp_chr, $temp_id);
	my ($temp_sub_transcript_ref, $temp_sample_array_ref, $temp_sample_hash_ref) = parse_list($temp_chr, $temp_id_ref, $temp_in, $temp_min_depth);
	$temp_date = `date $temp_date_format`;
	chomp $temp_date;
	print "[$temp_date]\tParsing file list done for $temp_chr!\n";
	print_gtf_bed_exp($temp_chr, $temp_gene_ref, $temp_transcript_ref, $temp_sub_transcript_ref, $temp_sample_array_ref, $temp_sample_hash_ref, $temp_dir, $temp_five_diff, $temp_three_diff);
	my $temp_finish_time = Benchmark->new;
	my $temp_time_spent = timediff($temp_finish_time, $temp_start_time);
	$temp_date = `date $temp_date_format`;
	chomp $temp_date;
	print "[$temp_date]\tDone for $temp_chr in " . timestr($temp_time_spent) , "!\n";

	return $temp_chr;
}

#Get chromosome
sub get_chromosome{
	my ($temp_gtf) = @_;
	my %temp_chr = ();
	open(my $temp_fh, $temp_gtf) or die "<ERROR> Cannot open $temp_gtf!\n";
	GTF:while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		if($temp_line =~ /^#/){
			next GTF;
		}
		my @temp_line = split('\t', $temp_line);
		if(@temp_line != 9){
			print STDERR "<ERROR> $temp_gtf doesn't seem to be in .gtf format.\n";
			exit;
		}
		unless(exists $temp_chr{$temp_line[0]}){
			$temp_chr{$temp_line[0]} = 1;
		}
	}
	close $temp_fh;
	my @temp_chr = keys %temp_chr;

	return \@temp_chr;
}

#Count the number of samples
sub count_sample{
	my ($temp_in) = @_;
	my $temp_num_sample = 0;
	open(my $temp_fh, $temp_in) or die "<ERROR> Cannot open $temp_in!\n";
	while(<$temp_fh>){
		chomp;
		my $temp_file = $_;
		$temp_file =~ s/\r//;
		$temp_num_sample++;
	}
	close $temp_fh;

	return $temp_num_sample;
}

#Read gtf file
sub read_gtf{
	my ($temp_chr, $temp_gtf) = @_;
	open(my $temp_fh, $temp_gtf) or die "<ERROR> Cannot open $temp_gtf!\n";
	my %temp_gene = ();
	my %temp_transcript = ();
	while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		my @temp_line = split('\t', $temp_line);
		if($temp_line[0] ne $temp_chr){
			next;
		}
		elsif(($temp_line[2] ne 'gene') && ($temp_line[2] ne 'transcript') && ($temp_line[2] ne 'exon')){
			next;
		}
		my $temp_gene_id;
		if($temp_line[8] =~ /(^|\s)gene_id \"([^\"]+)\"/){
			$temp_gene_id = $2;
		}
		else{
			print STDERR "<ERROR> gene_id missing at line\n$temp_line\n";
			exit;
		}
		if($temp_line[2] eq 'gene'){
			if(exists $temp_gene{$temp_gene_id}){
				print STDERR "<ERROR> Duplicated gene $temp_gene_id in $temp_gtf!\n";
				exit;
			}
			else{
				%{$temp_gene{$temp_gene_id}} = ();
				$temp_gene{$temp_gene_id}{'strand'} = $temp_line[6];
				$temp_gene{$temp_gene_id}{'left'} = $temp_line[3];
				$temp_gene{$temp_gene_id}{'right'} = $temp_line[4];
			}
		}
		else{
			my $temp_transcript_id;
			if($temp_line[8] =~ /(^|\s)transcript_id \"([^\"]+)\"/){
				$temp_transcript_id = $2;
			}
			else{
				print STDERR "<ERROR> transcript_id missing at line\n$temp_line\n";
				exit;
			}
			unless(exists $temp_transcript{$temp_transcript_id}){
				%{$temp_transcript{$temp_transcript_id}} = ();
				$temp_transcript{$temp_transcript_id}{'gene_id'} = $temp_gene_id;
				$temp_transcript{$temp_transcript_id}{'strand'} = $temp_line[6];
				@{$temp_transcript{$temp_transcript_id}{'exon'}} = ();
			}
			if($temp_line[2] eq 'transcript'){
				$temp_transcript{$temp_transcript_id}{'left'} = $temp_line[3];
				$temp_transcript{$temp_transcript_id}{'right'} = $temp_line[4];
			}
			elsif($temp_line[2] eq 'exon'){
				my $temp_exon_number;
				if($temp_line[8] =~ /(^|\s)exon_number \"([^\"]+)\"/){
					$temp_exon_number = $2;
				}
				else{
					print STDERR "<ERROR> exon_number missing at line\n$temp_line\n";
					exit;
				}
				my @temp_exon = ($temp_line[3], $temp_line[4], $temp_exon_number);
				push(@{$temp_transcript{$temp_transcript_id}{'exon'}}, \@temp_exon);
			}
		}
	}
	close $temp_fh;

	return (\%temp_gene, \%temp_transcript);
}

#Read the _id.txt file
sub read_id{
	my ($temp_chr, $temp_id) = @_;
	open(my $temp_fh, $temp_id) or die "Cannot open $temp_id!\n";
	my %temp_id = ();
	my $temp_header = 0;
	my %temp_header = ();
	while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		my @temp_line = split('\t', $temp_line);
		if($temp_header == 0){
			for(my $i = 0; $i < @temp_line; $i++){
				if(exists $temp_header{$temp_line[$i]}){
					print STDERR "<ERROR> Duplicated column $temp_line[$i] in $temp_id!\n";
					exit;
				}
				else{
					$temp_header{$temp_line[$i]} = $i;
				}
			}
			unless(exists $temp_header{'chr'}){
				print STDERR "<ERROR> chr absent in $temp_id!\n";
				exit;
			}
			unless(exists $temp_header{'transcript_id'}){
				print STDERR "<ERROR> transcript_id absent in $temp_id!\n";
				exit;
			}
			unless(exists $temp_header{'original_id'}){
				print STDERR "<ERROR> original_id absent in $temp_id!\n";
				exit;
			}
			$temp_header = 1;
		}
		else{
			if($temp_line[$temp_header{'chr'}] ne $temp_chr){
				next;
			}
			my @temp_original_id = split(',', $temp_line[$temp_header{'original_id'}]);
			foreach my $temp_original_id (@temp_original_id){
				if(exists $temp_id{$temp_original_id}){
					print ERROR "Duplicated ID $temp_original_id in $temp_id!\n";
					exit;
				}
				else{
					$temp_id{$temp_original_id} = $temp_line[$temp_header{'transcript_id'}];
				}
			}
		}
	}
	close $temp_fh;

	return (\%temp_id);
}

#Parse the list
sub parse_list{
	my ($temp_chr, $temp_id_ref, $temp_in, $temp_min_depth)= @_;
	my %temp_sub_transcript = ();
	my @temp_sample = ();
	my %temp_sample = ();
	my $temp_sample_count = 0;
	open(my $temp_fh, $temp_in) or die "<ERROR> Cannot open $temp_in!\n";
	while(<$temp_fh>){
		chomp;
		my $temp_file = $_;
		$temp_file =~ s/\r//;
		parse_end_dist($temp_chr, \%temp_sub_transcript, $temp_id_ref, $temp_file, $temp_min_depth);
		push(@temp_sample, $temp_file);
		$temp_sample{$temp_file} = $temp_sample_count;
		$temp_sample_count++;
	}
	close $temp_fh;

	return (\%temp_sub_transcript, \@temp_sample, \%temp_sample);
}

#Parse a end_dist.txt file
sub parse_end_dist{
	my ($temp_chr, $temp_sub_transcript_ref, $temp_id_ref, $temp_in, $temp_min_depth) = @_;
	open(my $temp_fh, $temp_in) or die "<ERROR> Cannot open $temp_in!\n";
	my %temp_header = ();
	my $temp_header = 0;
	while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		my @temp_line = split('\t', $temp_line);
		if($temp_header == 0){
			for(my $i = 0; $i < @temp_line; $i++){
				if(exists $temp_header{$temp_line[$i]}){
					print STDERR "<ERROR> Duplicated column $temp_line[$i] in $temp_in!\n";
					exit;
				}
				else{
					$temp_header{$temp_line[$i]} = $i;
				}
			}
			unless(exists $temp_header{'chr'}){
				print STDERR "<ERROR> chr absent in $temp_in!\n";
				exit;
			}
			unless(exists $temp_header{'transcript_id'}){
				print STDERR "<ERROR> transcript_id absent in $temp_in!\n";
				exit;
			}
			unless(exists $temp_header{'depth'}){
				print STDERR "<ERROR> depth absent in $temp_in!\n";
				exit;
			}
			unless(exists $temp_header{'end_dist'}){
				print STDERR "<ERROR> end_dist absent in $temp_in!\n";
				exit;
			}
			$temp_header = 1;
		}
		else{
			if(($temp_line[$temp_header{'chr'}] eq $temp_chr) && ($temp_line[$temp_header{'depth'}] >= $temp_min_depth)){
				my $temp_transcript_id = $temp_id_ref->{$temp_line[$temp_header{'transcript_id'}]};
				unless(exists $temp_sub_transcript_ref->{$temp_transcript_id}){
					%{$temp_sub_transcript_ref->{$temp_transcript_id}} = ();
				}
				my @temp_end_dist = split(',', $temp_line[$temp_header{'end_dist'}]);
				foreach my $temp_end_dist (@temp_end_dist){
					$temp_end_dist =~ /^([^:]+):(\d+)$/;
					my ($temp_ends, $temp_depth) = ($1, $2);
					unless(exists $temp_sub_transcript_ref->{$temp_transcript_id}{$temp_ends}){
						%{$temp_sub_transcript_ref->{$temp_transcript_id}{$temp_ends}} = ();
					}
					unless(exists $temp_sub_transcript_ref->{$temp_transcript_id}{$temp_ends}{$temp_in}){
						$temp_sub_transcript_ref->{$temp_transcript_id}{$temp_ends}{$temp_in} = $temp_depth;
					}
					#print "$temp_chr\t$temp_transcript_id\t$temp_end_dist\t$temp_ends\t$temp_in\t$temp_depth\n";
				}

			}
		}
	}
	close $temp_fh;

	return 1;
}

#Compare two 5'-3' combinations
sub compare_ends{
	my ($temp_ends_a, $temp_ends_b, $temp_strand, $temp_five_diff, $temp_three_diff) = @_;
	my @temp_ends_a = split('-', $temp_ends_a);
	my @temp_ends_b = split('-', $temp_ends_b);
	my $temp_diff = abs($temp_ends_a[0] - $temp_ends_b[0]);
	$temp_diff = abs($temp_ends_a[1] - $temp_ends_b[1]);
	if($temp_strand eq '-'){
		if((abs($temp_ends_a[1] - $temp_ends_b[1]) <= $temp_five_diff) && (abs($temp_ends_a[0] - $temp_ends_b[0]) <= $temp_three_diff)){

			return 1;
		}
	}
	else{
		if((abs($temp_ends_a[0] - $temp_ends_b[0]) <= $temp_five_diff) && (abs($temp_ends_a[1] - $temp_ends_b[1]) <= $temp_three_diff)){

			return 1;
		}
	}

	return 0;
}

#Find the representative 5'-3' combination
sub find_rep_ends{
	my ($temp_rep_ends_ref, $temp_query_ends) = @_;
	if($temp_rep_ends_ref->{$temp_query_ends} ne $temp_query_ends){
		my $temp_rep_ends = find_rep_ends($temp_rep_ends_ref, $temp_rep_ends_ref->{$temp_query_ends});

		return $temp_rep_ends;
	}
	else{
		return $temp_query_ends;
	}
}

#Merge sub-transcripts
sub merge_sub_transcript{
	my ($temp_rep_ends_ref, $temp_cluster_size_ref, $temp_rep_region_ref, $temp_ends_a, $temp_ends_b) = @_;
	my $temp_rep_ends_a = find_rep_ends($temp_rep_ends_ref, $temp_ends_a);
	my $temp_rep_ends_b = find_rep_ends($temp_rep_ends_ref, $temp_ends_b);
	if($temp_rep_ends_a eq $temp_rep_ends_b){

		return 0;
	}
	if($temp_cluster_size_ref->{$temp_rep_ends_a} > $temp_cluster_size_ref->{$temp_rep_ends_b}){
		#print "Making $temp_rep_ends_a as rep...\n@{$temp_rep_region_ref->{$temp_rep_ends_a}}\n@{$temp_rep_region_ref->{$temp_rep_ends_b}}\n";
		$temp_rep_ends_ref->{$temp_rep_ends_b} = $temp_rep_ends_a;
		$temp_cluster_size_ref->{$temp_rep_ends_a} += $temp_cluster_size_ref->{$temp_rep_ends_b};
		foreach my $i (0, 2){
			if($temp_rep_region_ref->{$temp_rep_ends_b}[$i] < $temp_rep_region_ref->{$temp_rep_ends_a}[$i]){
				$temp_rep_region_ref->{$temp_rep_ends_a}[$i] = $temp_rep_region_ref->{$temp_rep_ends_b}[$i];
			}
		}
		foreach my $i (1, 3){
			if($temp_rep_region_ref->{$temp_rep_ends_b}[$i] > $temp_rep_region_ref->{$temp_rep_ends_a}[$i]){
				$temp_rep_region_ref->{$temp_rep_ends_a}[$i] = $temp_rep_region_ref->{$temp_rep_ends_b}[$i];
			}
		}
		#print "@{$temp_rep_region_ref->{$temp_rep_ends_a}}\n";
	}
	else{
		#print "Making $temp_rep_ends_b as rep...\n@{$temp_rep_region_ref->{$temp_rep_ends_a}}\n@{$temp_rep_region_ref->{$temp_rep_ends_b}}\n";
		$temp_rep_ends_ref->{$temp_rep_ends_a} = $temp_rep_ends_b;
		$temp_cluster_size_ref->{$temp_rep_ends_b} += $temp_cluster_size_ref->{$temp_rep_ends_a};
		foreach my $i (0, 2){
			if($temp_rep_region_ref->{$temp_rep_ends_a}[$i] < $temp_rep_region_ref->{$temp_rep_ends_b}[$i]){
				$temp_rep_region_ref->{$temp_rep_ends_b}[$i] = $temp_rep_region_ref->{$temp_rep_ends_a}[$i];
			}
		}
		foreach my $i (1, 3){
			if($temp_rep_region_ref->{$temp_rep_ends_a}[$i] > $temp_rep_region_ref->{$temp_rep_ends_b}[$i]){
				$temp_rep_region_ref->{$temp_rep_ends_b}[$i] = $temp_rep_region_ref->{$temp_rep_ends_a}[$i];
			}
		}
		#print "@{$temp_rep_region_ref->{$temp_rep_ends_b}}\n";
	}

	return 1;
}

sub sub_transcript_cluster{
	my ($temp_ends_ref, $temp_strand, $temp_five_diff, $temp_three_diff) = @_;
	my %temp_rep_ends = ();
	my %temp_cluster_size = ();
	my %temp_rep_region = ();
	my %temp_cluster = ();
	my %temp_cluster_region = ();
	foreach my $temp_ends (keys %$temp_ends_ref){
		#print "$temp_ends\n";
		$temp_ends =~ /^(\d+)-(\d+)$/;
		my ($temp_left, $temp_right) = ($1, $2);
		unless(exists $temp_rep_region{$temp_ends}){
			@{$temp_rep_region{$temp_ends}} = ($temp_left, $temp_left, $temp_right, $temp_right);
		}
		unless(exists $temp_rep_ends{$temp_ends}){
			$temp_rep_ends{$temp_ends} = $temp_ends;
		}
		unless(exists $temp_cluster_size{$temp_ends}){
				$temp_cluster_size{$temp_ends} = 1;
		}
		unless(exists $temp_cluster{$temp_ends}){
			$temp_cluster{$temp_ends} = 0;
		}
	}
	my @temp_ends = keys %$temp_ends_ref;
	my $temp_num_ends = keys %$temp_ends_ref;
	for(my $i = 0; $i < ($temp_num_ends - 1); $i++){
		for(my $j = ($i + 1); $j < $temp_num_ends; $j++){
			#print "$temp_ends[$i] <-> $temp_ends[$j]\n";
			if(compare_ends($temp_ends[$i], $temp_ends[$j], $temp_strand, $temp_five_diff, $temp_three_diff)){
				#print "To be merged...\n";
				merge_sub_transcript(\%temp_rep_ends, \%temp_cluster_size, \%temp_rep_region, $temp_ends[$i], $temp_ends[$j]);
			}
		}
	}
	my $temp_cluster_count = 0;
	foreach my $temp_ends (sort {$temp_rep_region{$a}[0] <=> $temp_rep_region{$b}[0]} keys %temp_rep_region){
		if($temp_ends eq $temp_rep_ends{$temp_ends}){
			$temp_cluster_count++;
			$temp_cluster{$temp_ends} = $temp_cluster_count;
			$temp_cluster_region{$temp_cluster_count} = $temp_rep_region{$temp_ends};
			#print "$temp_ends as rep of cluster $temp_cluster{$temp_ends} (@{$temp_cluster_region{$temp_cluster_count}})\n";
			delete $temp_rep_region{$temp_ends};
		}
	}
	foreach my $temp_ends (keys %temp_rep_ends){
		if($temp_ends ne $temp_rep_ends{$temp_ends}){
			$temp_cluster{$temp_ends} = $temp_cluster{find_rep_ends(\%temp_rep_ends, $temp_ends)};
			#print "$temp_ends in cluster $temp_cluster{$temp_ends}\n";
			delete $temp_rep_region{$temp_ends};
		}
	}

	return (\%temp_cluster, \%temp_cluster_region);
}

#Print the record in gtf/bed format and the expression level
sub print_gtf_bed_exp{
	my ($temp_chr, $temp_gene_ref, $temp_transcript_ref, $temp_sub_transcript_ref, $temp_sample_array_ref, $temp_sample_hash_ref, $temp_dir, $temp_five_diff, $temp_three_diff) = @_;
	open(my $temp_gtf_fh, "> ${temp_dir}/${temp_chr}.gtf") or die "<ERROR> Cannot create ${temp_dir}/${temp_chr}.gtf!\n";
	open(my $temp_tss_fh, "> ${temp_dir}/${temp_chr}_tss.bed") or die "<ERROR> Cannot create ${temp_dir}/${temp_chr}_tss.bed!\n";
	open(my $temp_tts_fh, "> ${temp_dir}/${temp_chr}_tts.bed") or die "<ERROR> Cannot create ${temp_dir}/${temp_chr}_tts.bed!\n";
	open(my $temp_exp_fh, "> ${temp_dir}/${temp_chr}_exp.txt") or die "<ERROR> Cannot create ${temp_dir}/${temp_chr}_exp.txt!\n";
	foreach my $temp_gene_id (keys %$temp_gene_ref){
		print $temp_gtf_fh "$temp_chr\tisoPropeller\tgene\t$temp_gene_ref->{$temp_gene_id}{'left'}\t$temp_gene_ref->{$temp_gene_id}{'right'}\t.\t$temp_gene_ref->{$temp_gene_id}{'strand'}\t.\tgene_id \"$temp_gene_id\"\;\n";
	}
	foreach my $temp_transcript_id (keys %$temp_sub_transcript_ref){
		my $temp_strand = $temp_transcript_ref->{$temp_transcript_id}{'strand'};
		my $temp_exon = @{$temp_transcript_ref->{$temp_transcript_id}{'exon'}};
		#print "$temp_transcript_id\t$temp_strand\t$temp_exon\n";
		my ($temp_cluster_ref, $temp_cluster_region_ref) = sub_transcript_cluster($temp_sub_transcript_ref->{$temp_transcript_id}, $temp_strand, $temp_five_diff, $temp_three_diff);
		my %temp_exp = ();
		foreach my $temp_cluster (keys %$temp_cluster_region_ref){
			print $temp_gtf_fh "$temp_chr\tisoPropeller\ttranscript\t$temp_cluster_region_ref->{$temp_cluster}[0]\t$temp_cluster_region_ref->{$temp_cluster}[3]\t.\t$temp_strand\t.\tgene_id \"$temp_transcript_ref->{$temp_transcript_id}{'gene_id'}\"\; transcript_id \"${temp_transcript_id}_${temp_cluster}\"\;\n";
			my ($temp_tss_left, $temp_tss_right, $temp_tts_left, $temp_tts_right) = @{$temp_cluster_region_ref->{$temp_cluster}};
			if($temp_strand eq '-'){
				($temp_tss_left, $temp_tss_right, $temp_tts_left, $temp_tts_right) = ($temp_cluster_region_ref->{$temp_cluster}[2], $temp_cluster_region_ref->{$temp_cluster}[3], $temp_cluster_region_ref->{$temp_cluster}[0], $temp_cluster_region_ref->{$temp_cluster}[1]);
			}
			print $temp_tss_fh "$temp_chr\t$temp_tss_left\t$temp_tss_right\t${temp_transcript_id}_${temp_cluster}\t.\t$temp_strand\n";
			print $temp_tts_fh "$temp_chr\t$temp_tts_left\t$temp_tts_right\t${temp_transcript_id}_${temp_cluster}\t.\t$temp_strand\n";
			foreach my $temp_exon_ref (@{$temp_transcript_ref->{$temp_transcript_id}{'exon'}}){
				#print "@$temp_exon_ref\n";
				my ($temp_left, $temp_right, $temp_exon_number) = @$temp_exon_ref;
				if($temp_exon_number == 1){
					if($temp_exon == 1){
						$temp_left = $temp_cluster_region_ref->{$temp_cluster}[0];
						$temp_right = $temp_cluster_region_ref->{$temp_cluster}[3];
					}
					else{
						if($temp_strand eq '-'){
							$temp_right = $temp_cluster_region_ref->{$temp_cluster}[3];
						}
						else{
							$temp_left = $temp_cluster_region_ref->{$temp_cluster}[0];
						}
					}
				}
				elsif($temp_exon_number == $temp_exon){
					if($temp_strand eq '-'){
						$temp_left = $temp_cluster_region_ref->{$temp_cluster}[0];
					}
					else{
						$temp_right = $temp_cluster_region_ref->{$temp_cluster}[3];
					}
				}
				print $temp_gtf_fh "$temp_chr\tisoPropeller\texon\t$temp_left\t$temp_right\t.\t$temp_strand\t.\tgene_id \"$temp_transcript_ref->{$temp_transcript_id}{'gene_id'}\"\; transcript_id \"${temp_transcript_id}_${temp_cluster}\"\; exon_number \"$temp_exon_number\"\;\n";
			}
			@{$temp_exp{$temp_cluster}} = (0) x @$temp_sample_array_ref;
		}
		foreach my $temp_ends (keys %{$temp_sub_transcript_ref->{$temp_transcript_id}}){
			foreach my $temp_sample (keys %{$temp_sub_transcript_ref->{$temp_transcript_id}{$temp_ends}}){
				$temp_exp{$temp_cluster_ref->{$temp_ends}}[$temp_sample_hash_ref->{$temp_sample}] += $temp_sub_transcript_ref->{$temp_transcript_id}{$temp_ends}{$temp_sample};
			}
		}
		foreach my $temp_cluster (keys %temp_exp){
			my $temp_exp = join("\t", @{$temp_exp{$temp_cluster}});
			print $temp_exp_fh "${temp_transcript_id}_${temp_cluster}\t$temp_exp\n";
		}		
	}
	close $temp_gtf_fh;
	close $temp_tss_fh;
	close $temp_tts_fh;
	close $temp_exp_fh;
	
	return 1;
}





