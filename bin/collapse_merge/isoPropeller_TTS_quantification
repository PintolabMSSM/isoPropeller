#!/usr/bin/env perl
=start
Author: ALin
Purpose: To identify TTS clusters based on pooled read depth based on alist of isoPropeller's output file *_end_dist.txt.
Change log:
=cut

use strict;
use Getopt::Long;
use List::Util qw(max min);
use threads;
use Benchmark qw(:hireswallclock);

my $modal_meanshift = `dirname $0`;
chomp $modal_meanshift;
$modal_meanshift .= "/modal_meanshift";
unless(-e $modal_meanshift){
        print STDERR "$modal_meanshift not found. Please install the executable.\n";
        exit;
}

my $total_start_time = Benchmark->new;

my $version = "v1.1";

my ($in, $out, $id, $bandwidth, $epsilon, $num_thread, $help) = ("", "", "", 1000, 1, 1, 0);

my $usage = "Usage: perl isoPropeller_TTS_quantification.pl
	-i <String> Input list of _end_dist.txt file(s)
	-o <String> Output
	-d <String> The _id.txt file generated by isoPropeller_merge_*.pl
	-k <Integer> The bandwidth for clustering TTS (Default: $bandwidth)
	-e <Integer> The distance of convergence in clustering TTS (Default: $epsilon)
	-t <Integer> The number of threads to use (Default: $num_thread)
	-h <Boolean> Help
";

GetOptions(
	'i=s'	=>	\$in,
	'o=s'	=>	\$out,
	'd=s'	=>	\$id,
	'k=i'	=>	\$bandwidth,
	'e=i'	=>	\$epsilon,
	't=i'	=>	\$num_thread,
        'h!'    =>      \$help
);

if($help){
        print "$usage";
        exit;
}

unless($in && $out && $id){
	print "$usage";
	exit;
}

my $date_format = "+%F-%T.%3N";
my $date = `date $date_format`;
chomp $date;
print "[$date]\tperl isoPropeller_TTS_quantification_${version}.pl -i $in -o $out -d $id -k $bandwidth -e $epsilon -t $num_thread\n";

my $dir = "${out}__isoPropeller_TTS_quantification_temp";
if(-d $dir){
	print STDERR "<WARNNING> Temporary directory $dir exists! Will overwrite it...\n";
	system("rm ${dir}/*");
}
else{
	system("mkdir $dir");
}

my $total_thread = `grep -c \"^processor\" /proc/cpuinfo`;
chomp $total_thread;
$date = `date $date_format`;
chomp $date;
print "[$date]\tA total of $total_thread threads detected\n";

my $num_batch = $num_thread;
if($num_thread > $total_thread){
	print "<WARNING> Exceeding the maximal total number of threads! Setting the number of thread to $total_thread...";
	$num_thread = $total_thread;
}

my $start_time = Benchmark->new;
$date = `date $date_format`;
chomp $date;
print "[$date]\tStarting preprocessing...\n";
my $sample_ref = split_batch($dir, $in, $id, $num_batch);
my $finish_time = Benchmark->new;
my $time_spent = timediff($finish_time, $start_time);
$date = `date $date_format`;
chomp $date;
print "[$date]\tUsed ". timestr($time_spent) . " for preprocessing\n";

my $batch = 1;
my @thread = ();
my @running = ();

while(@thread < $num_batch){
	@running = threads->list(threads::running);
	if(@running < $num_thread){
		my $thread = threads->create(\&worker, $batch, $sample_ref, $dir, $date_format, $in, $bandwidth, $epsilon);
		push(@thread, $thread);
		$batch++;
	}
}

foreach my $thread (@thread){
	my @result = $thread->join();
	$date = `date $date_format`;
	chomp $date;
	print "[$date]\tJoined for $result[0]!\n";
}

open(my $in_fh, $in) or die "<ERROR> Cannot open $in!\n";
open(my $out_fh, "> $out") or die "<ERROR> Cannot create $out!\n";
print $out_fh "transcript_tts\tleft\tright";
while(<$in_fh>){
	chomp;
	my $file = $_;
	$file =~ s/\r//;
	print $out_fh "\t$file";
}
print $out_fh "\n";
close $in_fh;
close $out_fh;
system("cat ${dir}/*_count.txt | sort -k 1,1 >> $out");
$date = `date $date_format`;
chomp $date;
print "[$date]\tGenerated output file!\n";
system("rm -r ${dir}");
$date = `date $date_format`;
chomp $date;
print "[$date]\tCleaned temporary files!\n";

my $total_finish_time = Benchmark->new;
my $total_time_spent = timediff($total_finish_time, $total_start_time);
$date = `date $date_format`;
chomp $date;
print "[$date]\tTotal time used: ". timestr($total_time_spent) . "\n";

sub worker{
	my ($temp_batch, $temp_sample_ref, $temp_dir, $temp_date_format, $temp_in, $temp_bandwidth, $temp_epsilon) = @_;
	my $temp_date = `date $temp_date_format`;
	chomp $temp_date;
	print "[$temp_date]\tStarting to process batch $temp_batch...\n";
	my $temp_start_time = Benchmark->new;
	my ($temp_id_ref) = read_id("${temp_dir}/batch_${temp_batch}_id.txt");
	my %temp_tts_pool = ();
	my %temp_tts_depth = ();
	parse_end_dist($temp_batch, $temp_sample_ref, \%temp_tts_pool, \%temp_tts_depth, $temp_dir, $temp_id_ref);
	$temp_date = `date $temp_date_format`;
	chomp $temp_date;
	print "[$temp_date]\tParsing file list done for batch $temp_batch!\n";
	print_tts(\%temp_tts_pool, \%temp_tts_depth, $temp_batch, $temp_sample_ref, $temp_dir, $temp_bandwidth, $temp_epsilon);
	my $temp_finish_time = Benchmark->new;
	my $temp_time_spent = timediff($temp_finish_time, $temp_start_time);
	$temp_date = `date $temp_date_format`;
	chomp $temp_date;
	print "[$temp_date]\tDone for batch $temp_batch in " . timestr($temp_time_spent) , "!\n";

	return $temp_batch;
}

#Split into different batches
sub split_batch{
	my ($temp_dir, $temp_in, $temp_id, $temp_num_batch) = @_;
	my %temp_transcript = ();
	open(my $temp_fh, $temp_id) or die "<ERROR> Cannot open $temp_id!\n";
	my $temp_header = 0;
	my %temp_header = ();
	my $temp_header_line;
	my %temp_batch_fh = ();
	my %temp_id_batch = ();
	while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		my @temp_line = split('\t', $temp_line);
		if($temp_header == 0){
			$temp_header_line = $temp_line;
			for(my $i = 0; $i < @temp_line; $i++){
				if(exists $temp_header{$temp_line[$i]}){
					print STDERR "<ERROR> Duplicated column $temp_line[$i] in $temp_id!\n";
					exit;
				}
				else{
					$temp_header{$temp_line[$i]} = $i;
				}
			}
			unless(exists $temp_header{'chr'}){
				print STDERR "<ERROR> chr absent in $temp_id!\n";
				exit;
			}
			unless(exists $temp_header{'transcript_id'}){
				print STDERR "<ERROR> transcript_id absent in $temp_id!\n";
				exit;
			}
			unless(exists $temp_header{'original_id'}){
				print STDERR "<ERROR> original_id absent in $temp_id!\n";
				exit;
			}
			$temp_header = 1;
		}
		else{
			unless(exists $temp_transcript{$temp_line[$temp_header{'transcript_id'}]}){
				$temp_transcript{$temp_line[$temp_header{'transcript_id'}]} = $temp_line;
			}
		}
	}
	close $temp_fh;
	my $temp_batch_size = int((keys %temp_transcript) / $temp_num_batch) + 1;
	if(((keys %temp_transcript) / $temp_num_batch) == 1){
		$temp_batch_size = 1;
	}
	my ($temp_count, $temp_batch_count) = (0, 1);
	open($temp_fh, "> ${temp_dir}/batch_${temp_batch_count}_id.txt") or die "<ERROR> Cannot create ${temp_dir}/batch_${temp_batch_count}_id.txt!\n";
	open($temp_batch_fh{$temp_batch_count}, "> ${temp_dir}/batch_${temp_batch_count}_end_dist.txt") or die "<ERROR> Cannot create ${temp_dir}/batch_${temp_batch_count}_end_dist.txt!\n";
	print $temp_fh "$temp_header_line\n";
	foreach my $temp_transcript_id (keys %temp_transcript){
		$temp_count++;
		if($temp_count > ($temp_batch_size * $temp_batch_count)){
			close $temp_fh;
			$temp_batch_count++;
			open($temp_fh, "> ${temp_dir}/batch_${temp_batch_count}_id.txt") or die "<ERROR> Cannot create ${temp_dir}/batch_${temp_batch_count}_id.txt!\n";;
			open($temp_batch_fh{$temp_batch_count}, "> ${temp_dir}/batch_${temp_batch_count}_end_dist.txt") or die "<ERROR> Cannot create ${temp_dir}/batch_${temp_batch_count}_end_dist.txt!\n";
			print $temp_fh "$temp_header_line\n";
		}
		print $temp_fh "$temp_transcript{$temp_transcript_id}\n";
		my @temp_line = split('\t', $temp_transcript{$temp_transcript_id});
		my @temp_oid = split(',', $temp_line[$temp_header{'original_id'}]);
		foreach my $temp_oid (@temp_oid){
			unless(exists $temp_id_batch{$temp_oid}){
				$temp_id_batch{$temp_oid} = $temp_batch_count;
			}
		}
	}
	close $temp_fh;
	my @temp_sample = ();
	open($temp_fh, $temp_in) or die "<ERROR> Cannot open $temp_in!\n";
	while(<$temp_fh>){
		chomp;
		my $temp_file = $_;
		$temp_file =~ s/\r//;
		push(@temp_sample, $temp_file);
		split_end_dist(\%temp_batch_fh, \%temp_id_batch, $temp_file);
	}
	close $temp_fh;
	foreach my $temp_batch (keys %temp_batch_fh){
		close $temp_batch_fh{$temp_batch};
	}

	return \@temp_sample;
}

#Parse the file list
sub split_end_dist{
	my ($temp_batch_fh_ref, $temp_id_batch_ref, $temp_file) = @_;
	open(my $temp_ed_fh, $temp_file) or die "<ERROR> Cannot open $temp_file!\n";
	my %temp_header = ();
	my $temp_header = 0;
	while(<$temp_ed_fh>){
		chomp;
		my $temp_line = $_;
		my @temp_line = split('\t', $temp_line);
		if($temp_header == 0){
			for(my $i = 0; $i < @temp_line; $i++){
				if(exists $temp_header{$temp_line[$i]}){
					print STDERR "<ERROR> Duplicated column $temp_line[$i] in $temp_file!\n";
					exit;
				}
				else{
					$temp_header{$temp_line[$i]} = $i;
				}
			}
			unless(exists $temp_header{'chr'}){
				print STDERR "<ERROR> chr absent in $temp_file!\n";
				exit;
			}
			unless(exists $temp_header{'transcript_id'}){
				print STDERR "<ERROR> transcript_id absent in $temp_file!\n";
				exit;
			}
			unless(exists $temp_header{'depth'}){
				print STDERR "<ERROR> depth absent in $temp_file!\n";
				exit;
			}
			unless(exists $temp_header{'end_dist'}){
				print STDERR "<ERROR> end_dist absent in $temp_file!\n";
				exit;
			}
			$temp_header = 1;
			foreach my $temp_batch (keys %{$temp_batch_fh_ref}){
				print {$temp_batch_fh_ref->{$temp_batch}} "$temp_line\n";
			}
		}
		else{
			if(exists $temp_id_batch_ref->{$temp_line[$temp_header{'transcript_id'}]}){
				my $temp_batch = $temp_id_batch_ref->{$temp_line[$temp_header{'transcript_id'}]};
				print {$temp_batch_fh_ref->{$temp_batch}} "$temp_line\n";
			}
		}
	}

	return 1;
}

#Read the _id.txt file
sub read_id{
	my ($temp_id) = @_;
	open(my $temp_fh, $temp_id) or die "Cannot open $temp_id!\n";
	my %temp_id = ();
	my $temp_header = 0;
	my %temp_header = ();
	while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		my @temp_line = split('\t', $temp_line);
		if($temp_header == 0){
			for(my $i = 0; $i < @temp_line; $i++){
				if(exists $temp_header{$temp_line[$i]}){
					print STDERR "<ERROR> Duplicated column $temp_line[$i] in $temp_id!\n";
					exit;
				}
				else{
					$temp_header{$temp_line[$i]} = $i;
				}
			}
			unless(exists $temp_header{'chr'}){
				print STDERR "<ERROR> chr absent in $temp_id!\n";
				exit;
			}
			unless(exists $temp_header{'transcript_id'}){
				print STDERR "<ERROR> transcript_id absent in $temp_id!\n";
				exit;
			}
			unless(exists $temp_header{'original_id'}){
				print STDERR "<ERROR> original_id absent in $temp_id!\n";
				exit;
			}
			$temp_header = 1;
		}
		else{
			my @temp_original_id = split(',', $temp_line[$temp_header{'original_id'}]);
			foreach my $temp_original_id (@temp_original_id){
				if(exists $temp_id{$temp_original_id}){
					print STDERR "<ERROR> Duplicated ID $temp_original_id in $temp_id!\n";
					exit;
				}
				else{
					$temp_id{$temp_original_id} = $temp_line[$temp_header{'transcript_id'}];
				}
			}
		}
	}
	close $temp_fh;

	return (\%temp_id);
}

#Parse a end_dist.txt file
sub parse_end_dist{
	my ($temp_batch, $temp_sample_ref, $temp_tts_pool_ref, $temp_tts_depth_ref, $temp_dir, $temp_id_ref) = @_;
	open(my $temp_fh, "${temp_dir}/batch_${temp_batch}_end_dist.txt") or die "<ERROR> Cannot open ${temp_dir}/batch_${temp_batch}_end_dist.txt!\n";
	my %temp_header = ();
	my $temp_header = 0;
	my $temp_header_line;
	my $temp_num_sample = @$temp_sample_ref;
	my $temp_sample_count = 0;
	while(<$temp_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		my @temp_line = split('\t', $temp_line);
		if($temp_header == 0){
			for(my $i = 0; $i < @temp_line; $i++){
				if(exists $temp_header{$temp_line[$i]}){
					print STDERR "<ERROR> Duplicated column $temp_line[$i] in ${temp_dir}/batch_${temp_batch}_end_dist.txt!\n";
					exit;
				}
				else{
					$temp_header{$temp_line[$i]} = $i;
				}
			}
			unless(exists $temp_header{'chr'}){
				print STDERR "<ERROR> chr absent in ${temp_dir}/batch_${temp_batch}_end_dist.txt!\n";
				exit;
			}
			unless(exists $temp_header{'transcript_id'}){
				print STDERR "<ERROR> transcript_id absent in ${temp_dir}/batch_${temp_batch}_end_dist.txt!\n";
				exit;
			}
			unless(exists $temp_header{'depth'}){
				print STDERR "<ERROR> depth absent in ${temp_dir}/batch_${temp_batch}_end_dist.txt!\n";
				exit;
			}
			unless(exists $temp_header{'end_dist'}){
				print STDERR "<ERROR> end_dist absent in ${temp_dir}/batch_${temp_batch}_end_dist.txt!\n";
				exit;
			}
			$temp_header = 1;
			$temp_header_line = $temp_line
		}
		else{
			if($temp_line eq $temp_header_line){
				$temp_sample_count++;
			}
			elsif(exists $temp_id_ref->{$temp_line[$temp_header{'transcript_id'}]}){
				my $temp_transcript_id = $temp_id_ref->{$temp_line[$temp_header{'transcript_id'}]};
				my $temp_strand = $temp_line[$temp_header{'strand'}];
				unless(exists $temp_tts_pool_ref->{$temp_transcript_id}){
					%{$temp_tts_pool_ref->{$temp_transcript_id}} = ()
				}
				unless(exists $temp_tts_depth_ref->{$temp_transcript_id}){
					%{$temp_tts_depth_ref->{$temp_transcript_id}} = ();
				}
				my @temp_end_dist = split(',', $temp_line[$temp_header{'end_dist'}]);
				foreach my $temp_end_dist (@temp_end_dist){
					my ($temp_tts, $temp_depth);
					if($temp_end_dist =~ /^(\d+)-(\d+):(\d+)/){
						if($temp_strand eq '-'){
							$temp_tts = $1;
						}
						else{
							$temp_tts = $2;
						}
						$temp_depth = $3;
						#print "$temp_in\t$temp_transcript_id\t$temp_tts\t$temp_depth\n";
					}
					else{
						print STDERR "<ERROR> Incorrect format in ${temp_dir}/batch_${temp_batch}_end_dist.txt, line:\n$temp_line\n";
						exit;
					}
					unless(exists $temp_tts_pool_ref->{$temp_transcript_id}{$temp_tts}){
						$temp_tts_pool_ref->{$temp_transcript_id}{$temp_tts} = 0;
					}
					$temp_tts_pool_ref->{$temp_transcript_id}{$temp_tts} += $temp_depth;
					unless(exists $temp_tts_depth_ref->{$temp_transcript_id}{$temp_tts}){
						@{$temp_tts_depth_ref->{$temp_transcript_id}{$temp_tts}} = (0) x $temp_num_sample;
						#print "count $temp_sample_count: @{$temp_tts_depth_ref->{$temp_transcript_id}{$temp_tts}}\n";
					}
					$temp_tts_depth_ref->{$temp_transcript_id}{$temp_tts}[$temp_sample_count] += $temp_depth;
					#print "add: @{$temp_tts_depth_ref->{$temp_transcript_id}{$temp_tts}}\n";
				}
			}
		}
	}
	close $temp_fh;
	#foreach my $temp_transcript_id (keys %$temp_tts_depth_ref){
	#	foreach my $temp_tts (keys %{$temp_tts_depth_ref->{$temp_transcript_id}}){
	#		print "$temp_transcript_id\t$temp_tts\t@{$temp_tts_depth_ref->{$temp_transcript_id}{$temp_tts}}\n";
	#	}
	#}

	return 1;
}

#Print TTS count
sub print_tts{
	my ($temp_tts_pool_ref, $temp_tts_depth_ref, $temp_batch, $temp_sample_ref, $temp_dir, $temp_bandwidth, $temp_epsilon) = @_;
	open(my $temp_depth_fh, "> ${temp_dir}/batch_${temp_batch}_depth.txt") or die "<ERROR> Cannot create ${temp_dir}/batch_${temp_batch}_depth.txt!\n";
	open(my $temp_count_fh, "> ${temp_dir}/batch_${temp_batch}_count.txt") or die "<ERROR> Cannot create ${temp_dir}/batch_${temp_batch}_count.txt!\n";
	my $temp_num_sample = @$temp_sample_ref;
	foreach my $temp_transcript_id (keys %$temp_tts_pool_ref){
		my @temp_tts_input = ();
		foreach my $temp_tts (keys %{$temp_tts_pool_ref->{$temp_transcript_id}}){
			push(@temp_tts_input, "$temp_tts:$temp_tts_pool_ref->{$temp_transcript_id}{$temp_tts}");
		}
		my $temp_tts_input = join(",", @temp_tts_input);
		print $temp_depth_fh "$temp_transcript_id\t$temp_tts_input\n";
	}

	open(my	$temp_res_fh,  "$modal_meanshift ${temp_dir}/batch_${temp_batch}_depth.txt $temp_bandwidth $temp_epsilon |") or die "Cannot open cluster result for ${temp_dir}/batch_${temp_batch}_depth.txt!\n";
	while(<$temp_res_fh>){
		chomp;
		my $temp_line = $_;
		$temp_line =~ s/\r//;
		my ($temp_transcript_id, $temp_tts_cluster) = split('\t', $temp_line);
		#print "$temp_transcript_id\n$temp_tts_cluster\n";
		my @temp_tts_cluster = split(',', $temp_tts_cluster);
		my %temp_tts_cluster = ();
		my %temp_tts = ();
		#print "@temp_tts_cluster\n";
		foreach my $temp_pos_rep (@temp_tts_cluster){
			my @temp_pos_rep = split(':', $temp_pos_rep);
			#print "@temp_pos_rep\n";
			unless(exists $temp_tts_cluster{$temp_pos_rep[0]}){
				$temp_tts_cluster{$temp_pos_rep[0]} = $temp_pos_rep[1];
			}
			unless(exists $temp_tts{$temp_pos_rep[1]}){
				%{$temp_tts{$temp_pos_rep[1]}} = ();
				@{$temp_tts{$temp_pos_rep[1]}{'depth'}} = (0) x $temp_num_sample;
				$temp_tts{$temp_pos_rep[1]}{'left'} = $temp_pos_rep[0];
				$temp_tts{$temp_pos_rep[1]}{'right'} = $temp_pos_rep[0];
			}
			for(my $i = 0; $i < @{$temp_tts_depth_ref->{$temp_transcript_id}{$temp_pos_rep[0]}}; $i++){
				$temp_tts{$temp_pos_rep[1]}{'depth'}[$i] += $temp_tts_depth_ref->{$temp_transcript_id}{$temp_pos_rep[0]}[$i];
			}
			if($temp_tts{$temp_pos_rep[1]}{'left'} > $temp_pos_rep[0]){
				$temp_tts{$temp_pos_rep[1]}{'left'} = $temp_pos_rep[0];
			}
			if($temp_tts{$temp_pos_rep[1]}{'right'} < $temp_pos_rep[0]){
				$temp_tts{$temp_pos_rep[1]}{'right'} = $temp_pos_rep[0];
			}
		}
		foreach my $temp_cluster (sort {$a <=> $b} keys %temp_tts){
			my $temp_depth = join("\t", @{$temp_tts{$temp_cluster}{'depth'}});
			print $temp_count_fh "${temp_transcript_id}_$temp_cluster\t$temp_tts{$temp_cluster}{'left'}\t$temp_tts{$temp_cluster}{'right'}\t$temp_depth\n";
		}
	}
	close $temp_res_fh;
	close $temp_depth_fh;
	close $temp_count_fh;
	
	return 1;
}





