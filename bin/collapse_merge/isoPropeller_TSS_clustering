		}
		SJ:foreach my $temp_sj_id (keys %temp_sj){
			if($temp_sj_id =~ /monoexonic/){
				next SJ;
			}
			my @temp_tss_id = sort {$a <=> $b} keys %{$temp_sj{$temp_sj_id}};
			my $temp_tss_id = join(",", @temp_tss_id);
			my $temp_num_tss = @temp_tss_id;
			my $temp_num_transcript = 0;
			my @temp_transcript_id = ();
			foreach my $temp_tss_id_sub (@temp_tss_id){
				my $temp_transcript_id = join(",", @{$temp_sj{$temp_sj_id}{$temp_tss_id_sub}});
				push(@temp_transcript_id, $temp_transcript_id);
				$temp_num_transcript += @{$temp_sj{$temp_sj_id}{$temp_tss_id_sub}};
			}
			my $temp_transcript_id = join(";", @temp_transcript_id);
			print $temp_per_sj_fh "${temp_chr}_${temp_sj_id}_${temp_strand}\t$temp_tss_id\t$temp_num_tss\t$temp_transcript_id\t$temp_num_transcript\n";
		}
	}
	close $temp_tss_fh;
	close $temp_transcript_fh;
	close $temp_per_sj_fh;
	close $temp_first_sj_fh;
	close $temp_last_sj_fh;

	return 1;
}



